  private static generateHeroVisualElements(lead: any, brandAnalysis: BrandAnalysis): VisualElement[] {
    return [
      {
        type: 'image',
        src: lead.images?.[0] || '/images/hero-default.jpg',
        alt: `${lead.name} - Expert ${lead.sector}`,
        position: 'background',
        animation: 'parallax',
        purpose: 'establishment-credibility'
      },
      {
        type: 'video',
        src: '/videos/intro.mp4',
        alt: 'Présentation de nos services',
        position: 'overlay',
        animation: 'autoplay',
        purpose: 'engagement'
      },
      {
        type: 'icon',
        src: '/icons/quality.svg',
        alt: 'Garantie qualité',
        position: 'floating',
        animation: 'pulse',
        purpose: 'trust-signal'
      }
    ];
  }

  private static generateEmotionalHooks(lead: any, brandAnalysis: BrandAnalysis): EmotionalHook[] {
    const sector = lead.sector?.toLowerCase() || '';
    
    return [
      {
        type: 'pain',
        content: this.generatePainPoint(sector),
        intensity: 0.8,
        placement: 'hero-subtitle'
      },
      {
        type: 'gain',
        content: this.generateGainPoint(sector),
        intensity: 0.9,
        placement: 'hero-description'
      },
      {
        type: 'social',
        content: `${lead.googleReviews || '200'}+ clients satisfaits nous font confiance`,
        intensity: 0.7,
        placement: 'hero-footer'
      }
    ];
  }

  private static generateValueProposition(lead: any, brandAnalysis: BrandAnalysis): string {
    const sector = lead.sector?.toLowerCase() || '';
    const location = lead.city || '';
    
    return `L'alliance parfaite entre expertise ${sector} et service client exceptionnel à ${location}`;
  }

  private static generateDifferentiation(lead: any, brandAnalysis: BrandAnalysis): string {
    return `Seul expert ${lead.sector} à ${lead.city || 'votre région'} avec garantie satisfaction et suivi personnalisé`;
  }

  private static generateUrgencyElements(lead: any, brandAnalysis: BrandAnalysis): UrgencyElement[] {
    return [
      {
        type: 'time',
        content: 'Disponibilité limitée cette semaine',
        validity: '7 jours',
        impact: 'Prenez rendez-vous maintenant'
      },
      {
        type: 'quantity',
        content: 'Places limitées pour les créneaux premium',
        validity: 'jusqu\'à épuisement',
        impact: 'Réservez votre place'
      }
    ];
  }

  private static generateHeroSocialProof(lead: any, brandAnalysis: BrandAnalysis): SocialProofElement[] {
    return [
      {
        type: 'statistic',
        content: `${lead.googleReviews || '200'}+ clients satisfaits`,
        credibility: 'Avis Google vérifiés',
        placement: 'hero-stats'
      },
      {
        type: 'rating',
        content: `${lead.googleRating || '4.9'}/5 sur Google`,
        credibility: 'Note moyenne basée sur tous les avis',
        placement: 'hero-rating'
      }
    ];
  }

  // Méthodes utilitaires

  private static generateExperienceText(lead: any): string {
    const years = Math.floor(Math.random() * 15) + 5;
    return `${years}+ ans d'expérience`;
  }

  private static generateGuaranteeText(lead: any): string {
    const guarantees = [
      'Garantie satisfaction 100%',
      'Satisfaction ou remboursement',
      'Qualité garantie',
      'Service exceptionnel garanti'
    ];
    
    return guarantees[Math.floor(Math.random() * guarantees.length)];
  }

  private static generatePainPoint(sector: string): string {
    const painPoints: Record<string, string> = {
      restaurant: 'Fatigué des restaurants décevants ?',
      coiffeur: 'Insatisfait de votre coiffure actuelle ?',
      plomberie: 'Problèmes de plomberie récurrents ?',
      garage: 'Mécanicien peu fiable ?',
      hôtel: 'Hôtels qui ne répondent pas à vos attentes ?'
    };

    return painPoints[sector] || 'Insatisfait du service actuel ?';
  }

  private static generateGainPoint(sector: string): string {
    const gainPoints: Record<string, string> = {
      restaurant: 'Découvrez une expérience gastronomique inoubliable',
      coiffeur: 'Obtenez le style qui vous correspond vraiment',
      plomberie: 'Profitez de solutions durables et fiables',
      garage: 'Conduisez en toute sécurité et sérénité',
      hôtel: 'Vivez un séjour d\'exception et confort'
    };

    return gainPoints[sector] || 'Bénéficiez d\'un service exceptionnel';
  }

  private static getBaseServices(sector?: string): any[] {
    const servicesBySector: Record<string, any[]> = {
      restaurant: [
        { name: 'Cuisine Gastronomique', category: 'principal' },
        { name: 'Service Traiteur', category: 'evenementiel' },
        { name: 'Dégustation Vins', category: 'experience' },
        { name: 'Menu Enfant', category: 'famille' }
      ],
      coiffeur: [
        { name: 'Coupe Femme', category: 'feminin' },
        { name: 'Coupe Homme', category: 'masculin' },
        { name: 'Coloration', category: 'technique' },
        { name: 'Soins', category: 'bien-etre' }
      ],
      plomberie: [
        { name: 'Installation Sanitaire', category: 'neuf' },
        { name: 'Dépannage Urgence', category: 'urgence' },
        { name: 'Chauffage', category: 'confort' },
        { name: 'Diagnostic', category: 'expertise' }
      ],
      garage: [
        { name: 'Entretien', category: 'preventif' },
        { name: 'Réparation', category: 'curatif' },
        { name: 'Diagnostic', category: 'expertise' },
        { name: 'Carrosserie', category: 'esthetique' }
      ],
      hôtel: [
        { name: 'Chambres Standard', category: 'hebergement' },
        { name: 'Suites Premium', category: 'luxe' },
        { name: 'Restaurant', category: 'restauration' },
        { name: 'Spa', category: 'bien-etre' }
      ]
    };

    return servicesBySector[sector?.toLowerCase()] || [
      { name: 'Service Principal', category: 'core' },
      { name: 'Consultation', category: 'expertise' },
      { name: 'Support', category: 'service' }
    ];
  }

  private static enhanceServiceContent(service: any, lead: any, brandAnalysis: BrandAnalysis): ServiceContent {
    return {
      ...service,
      description: this.generateServiceDescription(service, lead, brandAnalysis),
      benefits: this.generateServiceBenefits(service, lead, brandAnalysis),
      features: this.generateServiceFeatures(service, lead, brandAnalysis),
      process: this.generateServiceProcess(service, lead, brandAnalysis),
      pricing: this.generateServicePricing(service, lead, brandAnalysis),
      guarantees: this.generateServiceGuarantees(service, lead, brandAnalysis),
      caseStudies: this.generateServiceCaseStudies(service, lead),
      faq: this.generateServiceFAQ(service, lead),
      testimonials: this.generateServiceTestimonials(service, lead),
      comparison: this.generateServiceComparison(service, lead)
    };
  }

  private static generateServiceDescription(service: any, lead: any, brandAnalysis: BrandAnalysis): string {
    return `Service ${service.name} de qualité exceptionnelle, adapté à vos besoins spécifiques avec expertise professionnelle et garantie satisfaction.`;
  }

  private static generateServiceBenefits(service: any, lead: any, brandAnalysis: BrandAnalysis): Benefit[] {
    return [
      {
        title: 'Qualité garantie',
        description: 'Service exécuté selon les plus hauts standards',
        outcome: 'Résultats exceptionnels et durables',
        timeline: 'Immédiat',
        measurement: 'Satisfaction client 100%',
        evidence: 'Avis clients vérifiés'
      },
      {
        title: 'Expertise professionnelle',
        description: 'Intervention par des experts certifiés',
        outcome: 'Solutions optimales et efficaces',
        timeline: 'Long terme',
        measurement: 'Taux de réussite 98%',
        evidence: 'Certifications professionnelles'
      }
    ];
  }

  private static generateServiceFeatures(service: any, lead: any, brandAnalysis: BrandAnalysis): Feature[] {
    return [
      {
        name: 'Expertise technique',
        description: 'Intervention par des professionnels qualifiés',
        technical: true,
        unique: false,
        standard: true,
        optional: false
      },
      {
        name: 'Garantie satisfaction',
        description: 'Satisfaction ou reprise gratuite',
        technical: false,
        unique: true,
        standard: false,
        optional: false
      }
    ];
  }

  private static generateServiceProcess(service: any, lead: any, brandAnalysis: BrandAnalysis): ServiceProcess[] {
    return [
      {
        step: 1,
        name: 'Consultation initiale',
        description: 'Analyse de vos besoins et objectifs',
        duration: '30 minutes',
        deliverables: ['Diagnostic', 'Recommandations'],
        requirements: ['Informations de base']
      },
      {
        step: 2,
        name: 'Proposition personnalisée',
        description: 'Solution adaptée à votre situation',
        duration: '24h',
        deliverables: ['Devis détaillé', 'Planning'],
        requirements: ['Validation du diagnostic']
      }
    ];
  }

  private static generateServicePricing(service: any, lead: any, brandAnalysis: BrandAnalysis): PricingInfo {
    return {
      model: 'forfaitaire',
      structure: [
        {
          name: 'Standard',
          price: 'À partir de 99€',
          features: ['Service de base', 'Garantie 1 an'],
          popular: false
        },
        {
          name: 'Premium',
          price: 'À partir de 199€',
          features: ['Service complet', 'Garantie 2 ans', 'Support prioritaire'],
          popular: true
        }
      ],
      value: {
        proposition: 'Meilleur rapport qualité-prix du secteur',
        justification: 'Expertise locale et garantie satisfaction'
      },
      transparency: {
        details: 'Aucun frais caché',
        conditions: 'Conditions claires et simples'
      },
      guarantees: [
        {
          type: 'satisfaction',
          description: 'Satisfaction ou remboursement',
          duration: '30 jours',
          conditions: 'Aucune condition'
        }
      ]
    };
