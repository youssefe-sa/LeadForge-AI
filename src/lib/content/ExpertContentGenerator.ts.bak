    const guarantee = this.generateGuaranteeText(lead);
    
    const subtitleTemplates: Record<string, string[]> = {
      restaurant: [
        `${experience} de tradition culinaire • ${guarantee}`,
        `Créations uniques et produits locaux • ${guarantee}`,
        `Ambiance raffinée et service exceptionnel • ${guarantee}`,
        `Innovation gastronomique et tradition • ${guarantee}`
      ],
      coiffeur: [
        `${experience} d'expertise capillaire • ${guarantee}`,
        `Tendances actuelles et techniques avancées • ${guarantee}`,
        `Produits professionnels et conseils personnalisés • ${guarantee}`,
        `Style unique et satisfaction garantie • ${guarantee}`
      ],
      plomberie: [
        `${experience} d'expertise technique • ${guarantee}`,
        `Intervention rapide 24/7 et solutions durables • ${guarantee}`,
        `Matériel certifié et techniciens qualifiés • ${guarantee}`,
        `Diagnostic précis et tarifs transparents • ${guarantee}`
      ],
      garage: [
        `${experience} d'expertise automobile • ${guarantee}`,
        `Diagnostic moderne et réparations précises • ${guarantee}`,
        `Pièces d'origine et garantie constructeur • ${guarantee}`,
        `Service client et suivi personnalisé • ${guarantee}`
      ],
      hôtel: [
        `${experience} d'excellence hôtelière • ${guarantee}`,
        `Confort absolu et service personnalisé • ${guarantee}`,
        `Localisation privilégiée et prestations premium • ${guarantee}`,
        `Attention aux détails et satisfaction totale • ${guarantee}`
      ]
    };

    const templates = subtitleTemplates[sector] || [
      `${experience} de professionnalisme • ${guarantee}`,
      `Expertise reconnue et service personnalisé • ${guarantee}`,
      `Qualité constante et innovation continue • ${guarantee}`,
      `Engagement total et satisfaction garantie • ${guarantee}`
    ];

    return templates[Math.floor(Math.random() * templates.length)];
  }

  private static generateExpertHeroDescription(lead: any, brandAnalysis: BrandAnalysis): string {
    const sector = lead.sector?.toLowerCase() || '';
    const location = lead.city || 'votre région';
    const values = brandAnalysis.values.coreValues.map(v => v.name).join(', ');
    
    return `
Découvrez l'excellence ${sector} à ${location}. Chez ${lead.name}, nous combinons 
${values} pour vous offrir des services exceptionnels qui dépassent vos attentes. 
Notre équipe d'experts passionnés met son savoir-faire et son expérience à votre 
disposition pour créer des solutions sur mesure qui répondent parfaitement à vos besoins.
    `.trim();
  }

