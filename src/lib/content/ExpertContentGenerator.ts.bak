  private static generateServiceCaseStudies(service: any, lead: any): string[] {
    return [
      `Étude de cas: ${service.name} pour client satisfait`,
      `Projet réussi: ${service.name} avec résultats exceptionnels`
    ];
  }

  private static generateServiceFAQ(service: any, lead: any): FAQItem[] {
    return [
      {
        question: `Quelle est la durée d'un ${service.name} ?`,
        answer: `La durée dépend de la complexité, généralement entre 1h et 4h.`,
        category: 'practical',
        priority: 'high'
      },
      {
        question: `Quel est le prix d'un ${service.name} ?`,
        answer: `Le prix varie selon vos besoins spécifiques, contactez-nous pour un devis personnalisé.`,
        category: 'pricing',
        priority: 'high'
      }
    ];
  }

  private static generateServiceTestimonials(service: any, lead: any): ServiceTestimonial[] {
    return [
      {
        client: 'Client satisfait',
        service: service.name,
        feedback: `Excellent service ${service.name}, professionnel et efficace.`,
        rating: 5,
        date: 'Il y a 1 semaine',
        context: 'Intervention standard'
      }
    ];
  }

  private static generateServiceComparison(service: any, lead: any): ComparisonPoint[] {
    return [
      {
        feature: 'Expertise',
