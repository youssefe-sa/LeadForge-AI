  private static enhanceTestimonialContent(testimonial: any, lead: any, brandAnalysis: BrandAnalysis): TestimonialContent {
    return {
      client: {
        name: testimonial.author,
        company: lead.sector,
        role: 'Client',
        industry: lead.sector,
        location: lead.city || 'France',
        since: '2023',
        type: 'individual'
      },
      story: {
        situation: 'Recherche d\'un service fiable',
        challenge: 'Services précédents décevants',
        solution: `Choix de ${lead.name}`,
        implementation: 'Processus simple et efficace',
        outcome: 'Résultats exceptionnels',
        timeline: 'Intervention rapide'
      },
      results: [
        {
          metric: 'Satisfaction',
          before: '60%',
          after: '100%',
          improvement: '+40%',
          timeframe: 'Immédiat',
          verification: 'Avis client'
        }
      ],
      experience: {
        firstContact: 'Réponse rapide et professionnelle',
        consultation: 'Écoute attentive et conseils pertinents',
        delivery: 'Service impeccable',
        support: 'Suivi personnalisé',
        followUp: 'Vérification de satisfaction'
      },
      recommendation: 'Je recommande sans hésiter',
      rating: testimonial.rating,
      context: {
        project: lead.sector,
        scope: 'Service standard',
        budget: 'Rapport qualité-prix excellent',
        timeline: 'Intervention rapide',
        complexity: 'Standard'
      },
      media: []
    };
  }

  // Interfaces additionnelles
  interface PortfolioContent {
    categories: string[];
    projects: ProjectContent[];
    filters: FilterContent[];
    presentation: PresentationContent;
  }

  interface ProjectContent {
    title: string;
    description: string;
    category: string;
    images: string[];
    details: ProjectDetails;
    results: ProjectResults;
  }

  interface FilterContent {
    name: string;
    value: string;
    count: number;
  }

  interface PresentationContent {
    layout: string;
    animation: string;
    interaction: string;
  }

  interface ProcessContent {
    title: string;
    description: string;
    steps: ProcessStep[];
    benefits: string[];
    timeline: string;
    guarantees: string[];
  }

  interface ProcessStep {
    number: number;
    title: string;
    description: string;
    duration: string;
    icon: string;
  }

  interface ContactContent {
    title: string;
    description: string;
    methods: ContactMethod[];
    information: ContactInformation;
    expectations: ContactExpectation[];
    urgency: ContactUrgency;
  }

  interface ContactMethod {
    type: string;
    label: string;
    value: string;
    icon: string;
    availability: string;
  }

  interface SEOContent {
    metadata: SEOMetadata;
    keywords: string[];
    content: SEOContentStrategy;
    local: LocalSEO;
    technical: TechnicalSEO;
  }

  interface SocialProofContent {
    statistics: SocialStatistic[];
    testimonials: SocialTestimonial[];
    certifications: SocialCertification[];
    partnerships: Partnership[];
    media: MediaMention[];
  }

  interface TrustSignalContent {
    guarantees: TrustGuarantee[];
    security: SecuritySignal[];
    transparency: TransparencySignal[];
    expertise: ExpertiseSignal[];
    social: SocialSignal[];
  }

  interface CaseStudyContent {
    title: string;
    client: string;
    challenge: string;
    solution: string;
    results: string[];
    timeline: string;
    images: string[];
  }

  interface BlogContent {
    title: string;
    excerpt: string;
    content: string;
    category: string;
    tags: string[];
    date: string;
    author: string;
  }

  interface FAQContent {
    categories: FAQCategory[];
    questions: FAQItem[];
    search: FAQSearch;
    help: FAQHelp;
  }

  // Types additionnels
  type Guarantee = any;
  type ServiceTestimonial = any;
  type FAQItem = any;
  type ProjectDetails = any;
  type ProjectResults = any;
  type ContactInformation = any;
  type ContactExpectation = any;
  type ContactUrgency = any;
  type SEOMetadata = any;
  type SEOContentStrategy = any;
  type LocalSEO = any;
  type TechnicalSEO = any;
  type SocialStatistic = any;
  type SocialTestimonial = any;
  type SocialCertification = any;
  type Partnership = any;
  type MediaMention = any;
  type TrustGuarantee = any;
  type SecuritySignal = any;
  type TransparencySignal = any;
  type ExpertiseSignal = any;
  type SocialSignal = any;
  type FAQCategory = any;
  type FAQSearch = any;
  type FAQHelp = any;

