  private static generateServiceGuarantees(service: any, lead: any, brandAnalysis: BrandAnalysis): Guarantee[] {
    return [
      {
        type: 'satisfaction',
        description: 'Satisfaction 100% garantie',
        duration: '30 jours',
        coverage: 'Remboursement complet',
        conditions: 'Aucune condition'
      },
      {
        type: 'quality',
        description: 'Qualité professionnelle garantie',
