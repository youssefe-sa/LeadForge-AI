{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "../dist/api",
    "baseUrl": ".",
    "paths": {
      "@vercel/node": ["./_types/vercel.d.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules", "../dist", "./_types"]
}
