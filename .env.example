# ============================================
# LeadForge AI - Variables d'environnement
# ============================================
# Copiez ce fichier en .env.local pour le développement local
# et configurez ces variables dans Vercel Dashboard > Settings > Environment Variables

# ============================================
# SUPABASE (Obligatoire)
# ============================================
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon-supabase

# ============================================
# API KEYS (Stockées côté serveur uniquement)
# ============================================
# Groq API - https://console.groq.com
GROQ_API_KEY=votre-cle-groq-gsk_

# Serper API - https://serper.dev
SERPER_API_KEY=votre-cle-serper

# OpenRouter API (optionnel) - https://openrouter.ai
OPENROUTER_API_KEY=votre-cle-openrouter

# Unsplash API (optionnel) - https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=votre-cle-unsplash

# Pexels API (optionnel) - https://www.pexels.com/api/
PEXELS_API_KEY=votre-cle-pexels

# ============================================
# EMAIL SMTP (Stocké côté serveur)
# ============================================
# Gmail SMTP - Créez un mot de passe d'application
# https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=votre-email@gmail.com
GMAIL_SMTP_PASSWORD=votre-mot-de-passe-application
GMAIL_SMTP_FROM_NAME=Votre Nom
GMAIL_SMTP_FROM_EMAIL=votre-email@gmail.com

# ============================================
# DEPLOIEMENT (Vercel)
# ============================================
# Ces variables sont automatiquement définies par Vercel
# VERCEL_URL=leadforge-ai.vercel.app
# VERCEL_ENV=production
